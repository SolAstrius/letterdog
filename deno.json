{
  "tasks": {
    "dev:http": "deno run --allow-net --allow-env --allow-read=.env main.ts",
    "dev:stdio": "MCP_TRANSPORT=stdio deno run --allow-net --allow-env --allow-read=.env main.ts",
    "smoke:http": "deno run --allow-net --allow-env --allow-read=.env scripts/mcp_smoke.ts",
    "probe:live": "deno run --allow-net --allow-env --allow-read=.env scripts/mcp_live_probe.ts",
    "schemas": "deno run --allow-net --allow-env --allow-read=.env --allow-write=schemas scripts/fetch_schemas.ts",
    "check": "deno fmt --check && deno lint && deno check main.ts scripts/fetch_schemas.ts scripts/mcp_smoke.ts scripts/mcp_live_probe.ts && deno test --allow-env --allow-read=.env --allow-net",
    "fmt": "deno fmt",
    "dev:v2:http": "deno run --allow-net --allow-env --allow-read=.env v2.ts",
    "dev:v2:stdio": "MCP_TRANSPORT=stdio deno run --allow-net --allow-env --allow-read=.env v2.ts",
    "cli": "deno run --allow-net --allow-env --allow-read --allow-write src/cli/main.ts",
    "check:v2": "deno check v2.ts 'src/core/**/*.ts' src/mcp/server.ts src/cli/main.ts"
  },
  "imports": {
    "@mcp/client": "npm:@modelcontextprotocol/sdk@1.29.0/client/index.js",
    "@mcp/client/streamable-http": "npm:@modelcontextprotocol/sdk@1.29.0/client/streamableHttp.js",
    "@mcp/server/mcp": "npm:@modelcontextprotocol/sdk@1.29.0/server/mcp.js",
    "@mcp/server/stdio": "npm:@modelcontextprotocol/sdk@1.29.0/server/stdio.js",
    "@mcp/server/web-standard-streamable-http": "npm:@modelcontextprotocol/sdk@1.29.0/server/webStandardStreamableHttp.js",
    "@mcp/shared/protocol": "npm:@modelcontextprotocol/sdk@1.29.0/shared/protocol.js",
    "@mcp/types": "npm:@modelcontextprotocol/sdk@1.29.0/types.js",
    "@nextcloud/cdav-library": "npm:@nextcloud/cdav-library@2.6.2",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@0.225.7",
    "html-to-text": "npm:html-to-text@9.0.5",
    "@xmldom/xmldom": "npm:@xmldom/xmldom@0.9.10",
    "fast-xml-parser": "npm:fast-xml-parser@5.3.2",
    "xpath": "npm:xpath@0.0.34",
    "zod": "npm:zod@4.4.3"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
