STALWART_BASE_URL=https://mail.astrius.ink
TEST_BEARER=
STALWART_BEARER=
STALWART_AUTHORIZATION=
STALWART_ALLOW_ENV_BEARER_FALLBACK=false
MCP_CONFIRMATION_SECRET=
MCP_TRANSPORT=http
PORT=8787
ENABLE_ADMIN_TOOLS=false

# OAuth resource-server (Stalwart is the authorization server; no separate IdP).
# PUBLIC_BASE_URL is the connector's public origin = OAuth resource id; when unset it is derived
# from X-Forwarded-Proto + Host per request. Set OAUTH_PROTECTED_RESOURCE=false to disable the
# RFC 9728 metadata endpoint + resource_metadata 401 challenge (legacy bare bearer challenge).
PUBLIC_BASE_URL=
OAUTH_PROTECTED_RESOURCE=true
OAUTH_AUTHORIZATION_SERVERS=
OAUTH_SCOPES=
# RFC 8707 resource advertised to clients. Leave blank to default to the authorization server
# (Stalwart) — Stalwart rejects any other resource indicator. Do NOT set to the connector's own URL.
OAUTH_RESOURCE=
# OAuth AS proxy: connector fronts Stalwart's OAuth so MCP clients (claude.ai) get zero-config login
# — DCR is downgraded to public PKCE, and resource/iss are rewritten. No credential needed.
OAUTH_PROXY=false
# OPTIONAL: Stalwart API key (authenticate + oauth-client-registration perms) to register clients
# as-requested (confidential) instead of the public-PKCE downgrade. Leave blank for zero-credential.
REGISTRATION_BEARER=
